[run]
branch = True
source = .
omit =
    */venv/*
    */tests/*
    */migrations/*
    config.py
    extensions.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if app.debug:
    if TESTING:

[html]
directory = htmlcov
