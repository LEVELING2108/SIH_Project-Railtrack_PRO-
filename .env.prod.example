# ============================================================
# Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ============================================================
# Flask Configuration
# ============================================================
FLASK_ENV=production
FLASK_DEBUG=False

# Generate secure keys with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-flask-key-change-this
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-db-password@db:5432/vendors

# PostgreSQL password (used in docker-compose)
POSTGRES_PASSWORD=your-secure-database-password

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins
# Production: Set to your frontend domain(s)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================
# Rate Limiting
# ============================================================
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=redis://redis:6379/0

# ============================================================
# JWT Configuration
# ============================================================
# Token expiration in seconds
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ============================================================
# Security
# ============================================================
# Session cookie settings
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# ============================================================
# Email Configuration (for notifications)
# ============================================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@gmail.com

# ============================================================
# External API Keys (optional)
# ============================================================
# GST_API_KEY=your-gst-api-key
# PAN_API_KEY=your-pan-api-key
# SMS_API_KEY=your-sms-api-key

# ============================================================
# Development (Override for local testing)
# ============================================================
# For local development, you can use:
# FLASK_ENV=development
# FLASK_DEBUG=true
# DATABASE_URL=sqlite:///vendors.db
# CORS_ORIGINS=http://localhost:3000
# RATELIMIT_ENABLED=false
